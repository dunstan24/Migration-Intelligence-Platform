# =============================================================
#  INTERLACE — BACKEND ENVIRONMENT CONFIG
#  Copy file ini ke backend/.env dan isi nilai yang kosong
#  JANGAN commit file ini ke git (.gitignore sudah handle ini)
# =============================================================


# ── App ──────────────────────────────────────────────────────
APP_NAME=Interlace Migration Intelligence API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
# Ganti ke "production" saat deploy ke Railway


# ── Database ─────────────────────────────────────────────────
# Development: pakai SQLite lokal (tidak perlu install apapun)
DATABASE_URL=sqlite+aiosqlite:///./data/processed/warehouse.db
SQLITE_PATH=./data/processed/warehouse.db

# Production: uncomment baris ini dan isi dari Railway dashboard
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname


# ── Redis ────────────────────────────────────────────────────
# Development: jalankan Redis via Docker → docker run -p 6379:6379 redis
# Production: Railway akan beri URL otomatis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Cache TTL (detik)
CACHE_DEFAULT_TTL=300
CACHE_LONG_TTL=3600


# ── Anthropic / Claude ───────────────────────────────────────
# Dapatkan API key dari: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=1024


# ── ChromaDB (RAG vector store) ──────────────────────────────
CHROMA_PERSIST_DIR=./data/embeddings
CHROMA_COLLECTION=migration_knowledge
RAG_TOP_K=5


# ── Embedding Model ──────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── ML Models ────────────────────────────────────────────────
MODELS_DIR=./ml/serialized
MODEL_A_FILE=model_a.joblib
MODEL_B_FILE=model_b.joblib
MODEL_C_FILE=model_c.joblib
MODEL_D_FILE=model_d.joblib


# ── Data Paths ───────────────────────────────────────────────
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed

# Subfolder per sumber data
EOI_DATA_DIR=./data/raw/eoi
OSL_DATA_DIR=./data/raw/osl
EMPLOYMENT_DATA_DIR=./data/raw/employment
MIGRATION_DATA_DIR=./data/raw/migration
STUDENT_DATA_DIR=./data/raw/student
VISA_DATA_DIR=./data/raw/visa
JSA_DATA_DIR=./data/raw/jsa
SA4_DATA_DIR=./data/raw/sa4
ARRIVALS_DATA_DIR=./data/raw/arrivals
TEMP_VISA_DATA_DIR=./data/raw/temp_visas
CANCELLATIONS_DATA_DIR=./data/raw/cancellations
ENGINE_DATA_DIR=./data/raw/engine


# ── Nama File Sumber Data ────────────────────────────────────
# Sesuaikan jika nama file berbeda
EOI_FILENAME=Complete_EOI_and_JSA_Data_October_2025.xlsx
EMPLOYMENT_FILENAME=employment_projections_may2025.xlsx
MIGRATION_FILENAME=migration_trends_statistical_2024-25.xlsx
STUDENT_FILENAME=student_temporary_visa_dataset_2015_2025.xlsx
VISA_GRANTS_FILENAME=visa_grants_extracted.xlsx
VISA_COSTS_FILENAME=australian_visa_costs.xlsx
SA4_FILENAME=labour_market_ratings_by_sa4.xlsx
FEATURES_FILENAME=occupation_state_features_2025-12.csv


# ── Auth / JWT ───────────────────────────────────────────────
# WAJIB diganti di production — buat string random panjang
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440


# ── CORS ─────────────────────────────────────────────────────
# Tambah URL Vercel kamu saat production
ALLOWED_ORIGINS=["http://localhost:3000","https://*.vercel.app"]


# ── Reports Output ───────────────────────────────────────────
REPORTS_OUTPUT_DIR=./data/reports
